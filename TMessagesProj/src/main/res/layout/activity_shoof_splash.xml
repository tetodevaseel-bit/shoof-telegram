<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <!-- poster grid background (cinematic effect) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:columnCount="3"
        android:alpha="0.18">
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#1a1a2e"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#16213e"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#0f3460"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#0f3460"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#1a1a2e"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#16213e"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#16213e"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#0f3460"/>
        <View android:layout_width="0dp" android:layout_height="220dp" android:layout_columnWeight="1" android:background="#1a1a2e"/>
    </GridLayout>

    <!-- dark gradient overlay top-to-bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"/>

    <!-- center content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp">

        <!-- Telegram logo circle -->
        <TextView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✈"
            android:textSize="44sp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:background="#FF2CA5E0"
            android:padding="10dp"/>

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Telegram"
            android:textColor="#FFFFFF"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_marginTop="20dp"/>

        <!-- tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="شاهد • استمتع • اشترك"
            android:textColor="#99FFFFFF"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- bottom section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="28dp"
        android:paddingBottom="52dp">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="ابدأ المشاهدة"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:background="#FF2CA5E0"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="سيطلب منك تسجيل دخول تيليجرام"
            android:textColor="#55FFFFFF"
            android:textSize="12sp"/>

    </LinearLayout>

</RelativeLayout>