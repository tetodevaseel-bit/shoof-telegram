<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- خلفية: شبكة ملصقات أفلام -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:alpha="0.25">

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal">
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1A3A5C" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#2D1B3D" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1A3A2D" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#3D2D1A" android:layout_margin="2dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal">
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#2D1A3A" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1A2D3A" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#3A2D1A" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1A3D2D" android:layout_margin="2dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal">
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#2A1A3D" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#3D2A1A" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1A2A3D" android:layout_margin="2dp"/>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#2D3A1A" android:layout_margin="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- تدرج من الأسفل للأعلى -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A0A0A"
        android:layout_gravity="bottom" />

    <!-- المحتوى الرئيسي -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center|bottom"
        android:padding="28dp"
        android:paddingBottom="60dp">

        <!-- شعار Telegram -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✈"
            android:textSize="64sp"
            android:textColor="#2AABEE"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- اسم التطبيق -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Telegram"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_gravity="center_horizontal" />

        <!-- شعار شوف -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="شوف"
            android:textColor="#2AABEE"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp" />

        <!-- وصف -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="شاهد آلاف المسلسلات والأنيميات\nبجودة عالية في أي مكان"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="40dp" />

        <!-- زر ابدأ -->
        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="ابدأ المشاهدة"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:background="#2AABEE"
            android:layout_marginBottom="14dp" />

        <!-- نص صغير -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="يتطلب حساب تيليجرام"
            android:textColor="#55FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
